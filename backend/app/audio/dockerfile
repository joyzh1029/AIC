# 1. Python 베이스 이미지 선택
FROM python:3.10-slim

# 2. 작업 디렉터리 설정
WORKDIR /app
# 2.1. 필요한 패키지 설치 (예: ffmpeg)
RUN apt-get update && apt-get install -y ffmpeg && rm -rf /var/lib/apt/lists/* # 캐시 제거

# 3. requirements.txt 복사 및 의존성 설치
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# 4. 전체 소스 복사 (audio만 아니라 app 전체를 컨테이너에 포함)
COPY ../../app ./app

# 5. FastAPI 서버 실행 (audio 라우터가 포함된 main.py 기준)
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8181"]
